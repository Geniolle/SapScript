<!doctype html>
<html lang="pt">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>SAP Script Web</title>
  <link rel="stylesheet" href="/static/styles.css">
</head>
<body>
  <main class="container">
    <header class="hero">
      <div>
        <p class="eyebrow">SAP Script</p>
        <h1>Cockpit SAP via Web</h1>
        <p class="subtitle">O botão web cria um pedido; o worker Windows executa o teu Cockpit no SAP GUI e devolve sempre o <code>STATUS</code> lido de <code>wnd[0]/sbar</code>.</p>
      </div>
      <div class="badge">Docker + Worker Windows</div>
    </header>

    <section class="grid">
      <form id="job-form" class="card">
        <h2>Novo pedido</h2>

        <label>
          Rotina
          <select name="task" required>
            <option value="sap_cockpit">Executar SAP Cockpit</option>
            <option value="ping_status">Ler STATUS atual do SAP</option>
            <option value="open_transaction">Abrir transação</option>
          </select>
        </label>

        <label>
          Ambiente
          <select name="ambiente">
            <option value="">Selecione o ambiente</option>
            {% for ambiente in ambientes %}
              <option value="{{ ambiente.codigo }}">
                {{ ambiente.label }}
              </option>
            {% endfor %}
          </select>
        </label>

        <label>
          Processo / pasta
          <select name="processo" id="processo-select">
            <option value="">Selecione o processo</option>
            {% for processo in processos %}
              <option value="{{ processo.nome }}">
                {{ processo.label }}
              </option>
            {% endfor %}
          </select>
        </label>

        <label>
          Subprocesso / ficheiro .py
          <select name="subprocesso" id="subprocesso-select">
            <option value="">Selecione primeiro o processo</option>
          </select>
        </label>

        <label>
          Caminho do ficheiro Excel no Windows, se a rotina pedir ficheiro
          <div style="display: flex; gap: 8px; align-items: center;">
            <input name="caminho_ficheiro" id="caminho-ficheiro-input" placeholder="Ex.: C:\SAP\ficheiro.xlsx" style="flex: 1;">
            <button type="button" id="select-excel-button" class="secondary">Selecionar no Windows</button>
          </div>
        </label>

        <label>
          Opção de request
          <select name="request_option">
            <option value="4">Não transportar</option>
            <option value="1">Usar request existente</option>
            <option value="2">Criar nova request</option>
          </select>
        </label>

        <label>
          Número da request
          <input name="request_number" placeholder="Ex.: S4QK900396">
        </label>

        <label>
          Descrição da nova request
          <input name="request_desc" placeholder="Ex.: REQUEST CRIADA VIA WEB">
        </label>

        <label>
          Tipo da nova request
          <select name="request_type">
            <option value="1">Customizing</option>
            <option value="2">Workbench</option>
          </select>
        </label>

        <label>
          Transação, para teste rápido
          <input name="transacao" placeholder="Ex.: SE10">
        </label>

        <button type="submit">Executar</button>
        <p id="form-message" class="message"></p>
      </form>

      <section class="card">
        <div class="section-header">
          <h2>Fila / Histórico</h2>
          <button id="refresh-button" type="button" class="secondary">Atualizar</button>
        </div>
        <div id="jobs" class="jobs"></div>
      </section>
    </section>
  </main>

  <script>
    const form = document.querySelector('#job-form');
    const formMessage = document.querySelector('#form-message');
    const jobsContainer = document.querySelector('#jobs');
    const refreshButton = document.querySelector('#refresh-button');
    const processoSelect = document.querySelector('#processo-select');
    const subprocessoSelect = document.querySelector('#subprocesso-select');
    const caminhoFicheiroInput = document.querySelector('#caminho-ficheiro-input');
    const selectExcelButton = document.querySelector('#select-excel-button');

    processoSelect.addEventListener('change', async () => {
      await loadSubprocessos();
    });

    selectExcelButton.addEventListener('click', async () => {
      await selectExcelFileOnWindows();
    });

    async function selectExcelFileOnWindows() {
      formMessage.textContent = 'A pedir ao worker Windows para abrir o seletor de ficheiro...';
      selectExcelButton.disabled = true;

      try {
        const payload = new FormData();
        payload.append('task', 'select_excel_file');
        payload.append('ambiente', '');
        payload.append('processo', processoSelect.value || '');
        payload.append('subprocesso', subprocessoSelect.value || '');
        payload.append('request_option', '4');
        payload.append('request_number', '');
        payload.append('request_desc', '');
        payload.append('request_type', '1');
        payload.append('caminho_ficheiro', caminhoFicheiroInput.value || '');
        payload.append('transacao', '');

        const response = await fetch('/jobs', {
          method: 'POST',
          body: payload
        });

        if (!response.ok) {
          formMessage.textContent = 'Erro ao criar pedido de seleção de ficheiro.';
          return;
        }

        const job = await response.json();
        formMessage.textContent = 'Pedido criado. Selecione o ficheiro na janela aberta pelo worker Windows.';

        const selectedPath = await waitForJobResult(job.id, 180000);

        caminhoFicheiroInput.value = selectedPath;
        formMessage.textContent = `Ficheiro selecionado: ${selectedPath}`;

        await loadJobs();
      }
      catch (error) {
        formMessage.textContent = error.message || 'Erro ao selecionar ficheiro no Windows.';
      }
      finally {
        selectExcelButton.disabled = false;
      }
    }

    async function waitForJobResult(jobId, timeoutMs) {
      const startedAt = Date.now();

      while (Date.now() - startedAt <= timeoutMs) {
        const response = await fetch(`/api/jobs/${encodeURIComponent(jobId)}`);

        if (!response.ok) {
          throw new Error('Não foi possível consultar o pedido de seleção de ficheiro.');
        }

        const job = await response.json();

        if (job.state === 'done') {
          const selectedPath = String(job.status || '').trim();

          if (!selectedPath) {
            throw new Error('O worker concluiu, mas não devolveu caminho de ficheiro.');
          }

          return selectedPath;
        }

        if (job.state === 'failed' || job.state === 'error') {
          const message = job.status || job.log || 'Seleção de ficheiro falhou no worker.';
          throw new Error(message);
        }

        await sleep(1000);
      }

      throw new Error('Tempo esgotado à espera da seleção de ficheiro no Windows.');
    }

    function sleep(ms) {
      return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function loadSubprocessos() {
      const processo = processoSelect.value || '';

      subprocessoSelect.innerHTML = '';

      if (!processo) {
        addSubprocessoOption('', 'Selecione primeiro o processo');
        return;
      }

      addSubprocessoOption('', 'A carregar subprocessos...');

      try {
        const response = await fetch(`/api/subprocesses?processo=${encodeURIComponent(processo)}`);

        if (!response.ok) {
          subprocessoSelect.innerHTML = '';
          addSubprocessoOption('', 'Erro ao carregar subprocessos');
          return;
        }

        const data = await response.json();
        const subprocessos = data.subprocesses || [];

        subprocessoSelect.innerHTML = '';

        if (!subprocessos.length) {
          addSubprocessoOption('', 'Nenhum subprocesso .py encontrado');
          return;
        }

        addSubprocessoOption('', 'Selecione o subprocesso');

        for (const subprocesso of subprocessos) {
          addSubprocessoOption(subprocesso.nome, subprocesso.label);
        }
      }
      catch {
        subprocessoSelect.innerHTML = '';
        addSubprocessoOption('', 'Erro ao carregar subprocessos');
      }
    }

    function addSubprocessoOption(value, text) {
      const option = document.createElement('option');
      option.value = value;
      option.textContent = text;
      subprocessoSelect.appendChild(option);
    }

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      formMessage.textContent = 'A criar pedido...';

      const task = form.querySelector('select[name="task"]').value;
      const processo = form.querySelector('select[name="processo"]').value;
      const subprocesso = form.querySelector('select[name="subprocesso"]').value;

      if (task === 'sap_cockpit' && (!processo || !subprocesso)) {
        formMessage.textContent = 'Para Executar SAP Cockpit, selecione Processo e Subprocesso.';
        return;
      }

      const response = await fetch('/jobs', {
        method: 'POST',
        body: new FormData(form)
      });

      if (!response.ok) {
        formMessage.textContent = 'Erro ao criar pedido.';
        return;
      }

      const job = await response.json();
      formMessage.textContent = `Pedido criado: ${job.id}`;
      await loadJobs();
    });

    refreshButton.addEventListener('click', loadJobs);

    async function loadJobs() {
      const response = await fetch('/api/jobs?limit=50');
      const data = await response.json();
      jobsContainer.innerHTML = '';

      if (!data.jobs.length) {
        jobsContainer.innerHTML = '<p class="muted">Ainda não existem pedidos.</p>';
        return;
      }

      for (const job of data.jobs) {
        const article = document.createElement('article');
        article.className = `job ${job.state}`;
        article.innerHTML = `
          <div class="job-top">
            <strong>${escapeHtml(job.task)}</strong>
            <span>${escapeHtml(job.state)}</span>
          </div>
          <p><b>STATUS:</b> ${escapeHtml(job.status || '')}</p>
          <details>
            <summary>Detalhes</summary>
            <pre>${escapeHtml(JSON.stringify(job.params, null, 2))}\n\n${escapeHtml(job.log || '')}</pre>
          </details>
          <small>${escapeHtml(job.created_at)} · ${escapeHtml(job.worker_name || 'sem worker')}</small>
        `;
        jobsContainer.appendChild(article);
      }
    }

    function escapeHtml(value) {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');
    }

    loadJobs();
    setInterval(loadJobs, 3000);
  </script>
</body>
</html>
