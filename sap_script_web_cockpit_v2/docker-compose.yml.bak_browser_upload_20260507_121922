services:
  sap-script-web:
    build: .
    container_name: sap-script-web
    ports:
      - "8010:8000"
    environment:
      DATA_DIR: /data
      WORKER_TOKEN: change-me
      SAP_SCRIPT_PROJECT_DIR: /sap-script
      UPLOADS_DIR: /uploads
      UPLOADS_WINDOWS_DIR: 'C:\workspace\sap-script\sap_script_uploads'
    volumes:
      - sap_script_data:/data
      - ..:/sap-script:ro
      - ../sap_script_uploads:/uploads
    restart: unless-stopped

volumes:
  sap_script_data:
