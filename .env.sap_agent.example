# JIRA
JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=replace-with-jira-api-token

# SAP RFC - read-only technical user
SAP_USER=SAP_READ_AGENT
SAP_PASSWD=replace-with-password
SAP_ASHOST=sap-qas-host.company.local
SAP_SYSNR=00
SAP_CLIENT=100
SAP_LANG=EN
