# Jira (nao usar valores reais neste ficheiro)
# URL base do Jira Cloud (ex: https://empresa.atlassian.net)
JIRA_DADOS_COMP_HASH=
# Caminho base da API (normalmente: rest/api/3)
JIRA_DADOS_HASH=rest/api/3
JIRA_EMAIL=
JIRA_TOKEN=

# Daemon
POLL_SECONDS=300
RUN_ONCE=true

# Em Docker, o compose usa /data/jira (mapeado para C:/Jira no host)
JIRA_DOWNLOAD_DIR=
SAP_LOGIN_ON_MAIN=true

# Controle da janela SAP durante o processamento:
# - show: deixa a janela visivel
# - minimize: minimiza para nao acompanhar a interacao
SAP_WINDOW_MODE=show

# Workflow por categoria (main.py)
WORKFLOW_ENABLED=true
# Pausa manual entre steps do workflow.
# Usar apenas em testes locais/interativos.
# true  = pede ENTER antes de cada step configurado em workflows.json
# false = execução automática normal
WORKFLOW_STEP_CONFIRM=false

WORKFLOW_AMBIENTE=QAD
WORKFLOW_SAP_KEY=S4DCLNT100
# Evidencias do workflow (Word + screenshots SAP)
WORKFLOW_DOC_ENABLED=false
# Opcional: pasta onde gravar o .docx e as imagens.
# Se vazio, grava na mesma pasta do ficheiro XLSX selecionado.
# Aceita placeholders do contexto, por exemplo:
# WORKFLOW_DOC_OUTPUT_DIR=C:/workspace/sap-script/Relatorios/{ticket_key}
# WORKFLOW_DOC_OUTPUT_DIR=C:/Jira/{ticket_key}
# WORKFLOW_DOC_OUTPUT_DIR=
# Opcional: override direto do sistema/mandante no workflow
# WORKFLOW_SAP_SYSTEM=S4D
# WORKFLOW_SAP_CLIENT=100
# Opcional: caminhos customizados
# WORKFLOW_CONFIG_PATH=
# WORKFLOW_STATE_PATH=
# WORKFLOW_PYTHON_EXEC=

# Gemini API Key for Explorar com IA chat
GEMINI_API_KEY=

# Teams - alerta de tickets sem responsável
# Envia mensagem no Microsoft Teams quando encontrar ticket JIRA com:
# Team = Core Systems e Responsável/Assignee vazio.
TEAMS_WEBHOOK_URL=
TEAMS_UNASSIGNED_ALERT_ENABLED=true
TEAMS_UNASSIGNED_TEAM=Core Systems
TEAMS_UNASSIGNED_TEAM_JQL_FIELD=cf[15839]
TEAMS_UNASSIGNED_TEAM_FIELD_ID=customfield_15839
TEAMS_UNASSIGNED_INCLUDE_DONE=false
TEAMS_UNASSIGNED_POLL_SECONDS=300
TEAMS_UNASSIGNED_STATE_PATH=/data/jira/teams_unassigned_alert_state.json
TEAMS_UNASSIGNED_DRY_RUN=false
TEAMS_UNASSIGNED_RUN_ONCE=false
# Opcional: substituir completamente o JQL padrão.
# TEAMS_UNASSIGNED_JQL=cf[15839] = "Core Systems" AND assignee IS EMPTY AND statusCategory != Done
